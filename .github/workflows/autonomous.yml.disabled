# .github/workflows/autonomous.yml
# BoggersTheMind — headless autonomous exploration (full Ollama + bulletproof commit)

name: Autonomous Exploration

on:
  schedule:
    - cron: '*/5 * * * *'   # Every 5 minutes
  workflow_dispatch:        # Allows manual trigger from Actions tab

permissions:
  contents: write

jobs:
  explore:
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install Python dependencies
        run: pip install -r requirements.txt

      # === Ollama setup (critical — fixes the dumb-model repetition loop) ===
      - name: Install Ollama
        run: curl -fsSL https://ollama.com/install.sh | sh

      - name: Start Ollama server
        run: ollama serve &

      - name: Wait + pull full model (llama3.2 — not the tiny 1b version)
        run: |
          sleep 15
          ollama pull llama3.2

      # === Run the mind (or Data Factory trace generator) ===
      - name: Run headless autonomous explorer
        env:
          GENERATE_TRACES: ${{ vars.GENERATE_TRACES || 'false' }}
        run: |
          mkdir -p logs data/training/raw
          if [ "$GENERATE_TRACES" = "true" ]; then
            python scripts/generate_ts_synthetic_data.py --mode github 2>&1 | tee logs/autonomous.log
          else
            python mind.py --headless 2>&1 | tee logs/autonomous.log
          fi
        timeout-minutes: 10

      # === Debug output ===
      - name: Show logs
        if: always()
        run: cat logs/autonomous.log 2>/dev/null || echo "No log file generated"

      # === Commit any new insights (and traces when GENERATE_TRACES=true) ===
      - name: Commit vault and graph changes
        run: |
          git config user.name "BoggersTheMind Bot"
          git config user.email "bot@boggersthemind.local"
          
          if git status --porcelain | grep -q .; then
            git add obsidian/ data/ logs/ 2>/dev/null || true
            if [ "$GENERATE_TRACES" = "true" ]; then
              git add data/training/raw/ 2>/dev/null || true
            fi
            git commit -m "Autonomous: new insights from exploration" || true
            git push
            echo "✅ Bot committed new insights!"
          else
            echo "ℹ️ No new insights this cycle (graph was quiet — normal)"
          fi
        if: always()
        env:
          GENERATE_TRACES: ${{ vars.GENERATE_TRACES || 'false' }}
